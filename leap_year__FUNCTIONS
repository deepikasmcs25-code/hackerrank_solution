def is_leap(year):
    leap = False
    if(year%4==0 and year%100!=0)or(year%400==0):# This function checks whether a given year is a leap year.
                                                 # A leap year is divisible by 4, not divisible by 100,
                                                 # unless it is also divisible by 400.
        leap=True
    return leap                                  

year = int(input())
print(is_leap(year))
